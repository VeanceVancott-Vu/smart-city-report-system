POSTGRES_DB=smart_city
POSTGRES_USER=smart_city_user
POSTGRES_PASSWORD=change_me_for_local_dev
POSTGRES_PORT=55432

# Spring Boot backend settings.
# application.yml reads these values from the environment or this .env file.
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:55432/smart_city
SPRING_DATASOURCE_USERNAME=smart_city_user
SPRING_DATASOURCE_PASSWORD=change_me_for_local_dev
JWT_SECRET=replace_me_with_at_least_32_random_characters
JWT_EXPIRATION_MINUTES=120
APP_FILE_UPLOAD_DIR=./uploads
APP_FILE_MAX_UPLOAD_SIZE=5MB
APP_CORS_ALLOWED_ORIGINS=http://localhost:5200,http://127.0.0.1:5200,http://localhost:5201,http://127.0.0.1:5201

# FastAPI AI service settings
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SERVICE_BASE_URL=http://localhost:8000
AI_PRIORITY_ENABLED=true
AI_PRIORITY_CONNECT_TIMEOUT=1s
AI_PRIORITY_READ_TIMEOUT=2s

# Flutter frontend examples.
# Flutter does not read this .env file at runtime. Use:
#   frontend-flutter/config/local_web.json
#   frontend-flutter/config/android_emulator.json
# or pass --dart-define=API_BASE_URL=...
